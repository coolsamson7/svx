{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "types": [
      "reflect-metadata",
      "vitest/globals"
    ],
    "paths": {
      "@svx/common": ["libs/common/src/index.ts"],
      "@svx/di": ["libs/di/src/index.ts"],
      "@svx/core": ["libs/core/src/index.ts"],
      "@svx/security": ["libs/security/src/index.ts"],
      "@svx/portal": ["libs/portal/src/index.ts"],
      "@svx/service-common": ["libs/service/common/src/index.ts"],
      "@svx/service-nestjs": ["libs/service/nestjs/src/index.ts"],
      "@svx/service-client": ["libs/service/client/src/index.ts"],

      "@svx/user-interface": ["libs/user/interface/src/index.ts"],
      "@svx/user-core": ["libs/user/core/src/index.ts"],
      "@svx/security-oidc": ["libs/security/oidc/src/index.ts"],
      "@svx/security-credentials": ["libs/security/credentials/src/index.ts"],
      "@svx/security-nestjs": ["libs/security/nestjs/src/index.ts"]
    }
  }
}
