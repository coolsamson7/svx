<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.1"
  xmlns:xmi="http://schema.omg.org/spec/XMI/2.1"
  xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML">

  <!-- ── DataTypes ─────────────────────────────────────────────────────────── -->

  <packagedElement xmi:type="uml:DataType" xmi:id="SmallString" name="SmallString">
    <ownedComment><body>Short text field — max 100 characters.</body></ownedComment>
    <taggedValue tag="base-type" value="string"/>
    <taggedValue tag="max-length" value="100"/>
  </packagedElement>

  <!-- ── User ──────────────────────────────────────────────────────────────── -->

  <packagedElement xmi:type="uml:Class" xmi:id="User" name="User">
    <ownedComment><body>A registered user of the platform.</body></ownedComment>

    <ownedAttribute xmi:type="uml:Property" xmi:id="User.id" name="id">
      <ownedComment><body>Auto-generated primary key.</body></ownedComment>
      <type xmi:idref="Integer"/>
      <lowerValue xmi:type="uml:LiteralInteger" value="1"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" value="1"/>
      <taggedValue tag="primary-key" value="true"/>
      <taggedValue tag="generated" value="increment"/>
    </ownedAttribute>

    <ownedAttribute xmi:type="uml:Property" xmi:id="User.name" name="name">
      <ownedComment><body>Display name of the user.</body></ownedComment>
      <type xmi:idref="SmallString"/>
      <lowerValue xmi:type="uml:LiteralInteger" value="1"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" value="1"/>
    </ownedAttribute>

    <ownedAttribute xmi:type="uml:Property" xmi:id="User.email" name="email">
      <ownedComment><body>Unique email address used for login.</body></ownedComment>
      <type xmi:idref="String"/>
      <lowerValue xmi:type="uml:LiteralInteger" value="1"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" value="1"/>
      <taggedValue tag="max-length" value="200"/>
      <taggedValue tag="email" value="true"/>
      <defaultValue xmi:type="uml:LiteralString" value=""/>
    </ownedAttribute>

    <!-- navigation: 1 User → * Address (cascade ORM saves) -->
    <ownedAttribute xmi:type="uml:Property" xmi:id="User.addresses" name="addresses"
                    association="assoc_User_Address">
      <ownedComment><body>Delivery and billing addresses belonging to this user.</body></ownedComment>
      <type xmi:idref="Address"/>
      <lowerValue xmi:type="uml:LiteralInteger" value="0"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" value="*"/>
      <taggedValue tag="cascade" value="true"/>
    </ownedAttribute>
  </packagedElement>

  <!-- ── Address ───────────────────────────────────────────────────────────── -->

  <packagedElement xmi:type="uml:Class" xmi:id="Address" name="Address">
    <ownedComment><body>A physical address associated with a user.</body></ownedComment>

    <ownedAttribute xmi:type="uml:Property" xmi:id="Address.id" name="id">
      <ownedComment><body>Auto-generated primary key.</body></ownedComment>
      <type xmi:idref="Integer"/>
      <lowerValue xmi:type="uml:LiteralInteger" value="1"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" value="1"/>
      <taggedValue tag="primary-key" value="true"/>
      <taggedValue tag="generated" value="increment"/>
    </ownedAttribute>

    <ownedAttribute xmi:type="uml:Property" xmi:id="Address.city" name="city">
      <ownedComment><body>Name of the city.</body></ownedComment>
      <type xmi:idref="SmallString"/>
      <lowerValue xmi:type="uml:LiteralInteger" value="1"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" value="1"/>
    </ownedAttribute>

    <!-- navigation: * Address → 1 User (owns the FK; DB cascade delete) -->
    <ownedAttribute xmi:type="uml:Property" xmi:id="Address.user" name="user"
                    association="assoc_User_Address">
      <ownedComment><body>The user this address belongs to.</body></ownedComment>
      <type xmi:idref="User"/>
      <lowerValue xmi:type="uml:LiteralInteger" value="1"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" value="1"/>
      <taggedValue tag="on-delete" value="CASCADE"/>
    </ownedAttribute>
  </packagedElement>

  <!-- ── Primitives ────────────────────────────────────────────────────────── -->

  <packagedElement xmi:type="uml:PrimitiveType" xmi:id="Integer" name="Integer"/>
  <packagedElement xmi:type="uml:PrimitiveType" xmi:id="String" name="String"/>

  <!-- ── Associations ──────────────────────────────────────────────────────── -->

  <!-- User 1 ──< Address (User owns the cascade, Address owns the FK column) -->
  <packagedElement xmi:type="uml:Association" xmi:id="assoc_User_Address" name="UserAddress">
    <memberEnd xmi:idref="User.addresses"/>
    <memberEnd xmi:idref="Address.user"/>
  </packagedElement>

</xmi:XMI>
