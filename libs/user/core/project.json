{
  "name": "@svx/user-core",
  "sourceRoot": "libs/user/core/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["^build"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "main": "libs/user/core/src/index.ts",
        "tsConfig": "libs/user/core/tsconfig.lib.json",
        "outputPath": "dist/libs/user/core"
      }
    },
    "compile-xmi": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx tools/xmi-compiler/src/index.ts libs/user/core/compiler.yaml",
        "cwd": "{workspaceRoot}"
      }
    },
    "generate-rest-proxies": {
      "executor": "nx:run-commands",

      "options": {
        "command": "npx tsx --tsconfig tools/ts-rest-proxy-reflector/tsconfig.json tools/ts-rest-proxy-reflector/src/cli.ts --tsconfig {projectRoot}/tsconfig.lib.json --out {projectRoot}/rest-proxies.json",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
